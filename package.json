{
  "name": "sy-nl-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "scripts": {
    "master": "npx tsx scripts/00-master.ts",
    "dev": "next dev -p 3000",
    "build": "prisma generate && prisma db push --accept-data-loss && node prisma/seed.cjs && next build",
    "start": "next start -p 3000",
    "prod": "next build && next start -p 3000",
    "lint": "eslint .",
    "fix-images": "node fix-images.mjs",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "sync": "npx tsx scripts/01-sync-facebook.ts",
    "sync:once": "npx tsx scripts/01-sync-facebook.ts",
    "reclassify": "npx tsx scripts/03-reclassify-posts.ts",
    "db:reset-sync": "npx tsx scripts/04-reset-and-sync.ts",
    "check-db": "npx tsx scripts/06-check-database.ts",
    "diagnose-fb": "npx tsx scripts/07-diagnose-facebook.ts",
    "sync:cron": "pm2 start ecosystem.config.js --only sy-nl-sync",
    "import:facebook": "npx tsx scripts/02-import-facebook.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "i18n:check": "npx tsx scripts/08-validate-i18n.ts",
    "faqs:seed": "npx tsx scripts/09-seed-faqs.ts",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t sy-nl .",
    "docker:run": "docker run -p 3001:3001 sy-nl"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@playwright/test": "^1.60.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-toast": "^1.2.14",
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@upstash/redis": "^1.28.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "linebreak": "^1.1.0",
    "lucide-react": "^0.525.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.7",
    "pdfkit": "^0.18.0",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "4.1.8"
  }
}
