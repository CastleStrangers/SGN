{
  "name": "sy-nl-platform",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "scripts": {
    "dev": "next dev -p 3000 --webpack",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "prod": "next build && next start -p 3001",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "sync": "npx tsx scripts/sync.ts",
    "sync:once": "npx tsx scripts/sync.ts",
    "reclassify": "npx tsx scripts/reclassify.ts",
    "db:reset-sync": "npx tsx scripts/reset-and-sync.ts",
    "sync:cron": "pm2 start ecosystem.config.js --only sy-nl-sync",
    "import:facebook": "npx tsx scripts/import-facebook.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "i18n:check": "npx tsx scripts/check-arabic.ts",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t sy-nl .",
    "docker:run": "docker run -p 3001:3001 sy-nl"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.3",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@playwright/test": "^1.60.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-text": "^10.0.0",
    "lucide-react": "^0.525.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "openai": "^4.100.0",
    "pdfkit": "^0.18.0",
    "playwright": "^1.60.0",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "tsx": "^4.19.2",
    "vitest": "^4.1.8"
  }
}
