generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              String             @default("member")
  roleId            String?
  bio               String?
  phone             String?
  location          String?
  website           String?
  createdAt         DateTime           @default(now())
  accounts          Account[]
  courses           Course[]
  courseEnrollments CourseEnrollment[]
  favorites         Favorite[]
  jobs              Job[]
  jobApplications   JobApplication[]
  liveStreams       LiveStream[]
  members           Member?
  posts             Post[]
  pushTokens        PushToken[]
  serviceReviews    ServiceReview[]    @relation("UserReviews")
  sessions          Session[]
  roleRel           Role?              @relation(fields: [roleId], references: [id])
  permissions       UserPermission[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id             String     @id @default(cuid())
  title          String
  slug           String?    @unique
  content        String
  excerpt        String?
  image          String?
  videoId        String?
  category       String     @default("أخبار الجالية")
  tags           String?
  source         String?    @default("الجالية السورية في هولندا")
  featured       Boolean    @default(false)
  views          Int        @default(0)
  published      Boolean    @default(true)
  membersOnly    Boolean    @default(false)
  authorId       String
  province       String?
  city           String?
  relatedEventId String?
  relatedTaskId  String?
  locale         String     @default("ar")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  comments       Comment[]
  favorites      Favorite[]
  author         User       @relation(fields: [authorId], references: [id])

  @@index([published, createdAt])
  @@index([category, published, createdAt])
  @@index([source, published])
  @@index([featured, published])
  @@index([locale, published, createdAt])
}

model LiveStream {
  id           String            @id @default(cuid())
  title        String
  description  String?
  thumbnail    String?
  streamUrl    String
  streamKey    String?
  platform     String            @default("youtube")
  status       String            @default("scheduled")
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  viewerCount  Int               @default(0)
  maxViewers   Int               @default(0)
  featured     Boolean           @default(false)
  membersOnly  Boolean           @default(false)
  authorId     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  chatMessages LiveChatMessage[]
  author       User              @relation(fields: [authorId], references: [id])

  @@index([status, scheduledAt])
  @@index([featured, status])
  @@index([authorId])
}

model LiveChatMessage {
  id          String     @id @default(cuid())
  content     String
  authorName  String?
  authorEmail String?
  streamId    String
  createdAt   DateTime   @default(now())
  stream      LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId, createdAt])
}

model Course {
  id           String             @id @default(cuid())
  title        String
  description  String?
  thumbnail    String?
  category     String             @default("general")
  level        String             @default("beginner")
  duration     Int?
  price        Float              @default(0)
  published    Boolean            @default(false)
  featured     Boolean            @default(false)
  instructorId String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  instructor   User               @relation(fields: [instructorId], references: [id])
  enrollments  CourseEnrollment[]
  lessons      Lesson[]

  @@index([published, createdAt])
  @@index([category, published])
  @@index([featured, published])
  @@index([instructorId])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  videoId     String?
  duration    Int?
  order       Int
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  courseId    String
  userId      String
  progress    Float     @default(0)
  completed   Boolean   @default(false)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
  @@index([courseId])
}

model Job {
  id           String           @id @default(cuid())
  title        String
  description  String
  company      String?
  location     String?
  city         String?
  province     String?
  type         String           @default("full-time")
  category     String           @default("general")
  salary       String?
  requirements String?
  remote       Boolean          @default(false)
  published    Boolean          @default(false)
  featured     Boolean          @default(false)
  expiresAt    DateTime?
  authorId     String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  author       User             @relation(fields: [authorId], references: [id])
  applications JobApplication[]

  @@index([published, createdAt])
  @@index([category, published])
  @@index([featured, published])
  @@index([city, published])
  @@index([province, published])
  @@index([expiresAt])
  @@index([authorId])
}

model JobApplication {
  id          String    @id @default(cuid())
  jobId       String
  userId      String
  status      String    @default("pending")
  coverLetter String?
  resumeUrl   String?
  appliedAt   DateTime  @default(now())
  reviewedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
}

model Task {
  id           String            @id @default(cuid())
  title        String
  description  String?
  status       String            @default("pending")
  priority     String            @default("medium")
  assignedTo   String?
  createdBy    String?
  dueDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  city         String?
  province     String?
  applications TaskApplication[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  author    String
  content   String
  userId    String?
  parentId  String?
  likes     Int       @default(0)
  approved  Boolean   @default(true)
  createdAt DateTime  @default(now())
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String?
  date          DateTime
  location      String?
  image         String?
  category      String              @default("فعالية")
  published     Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  city          String?
  province      String?
  registrations EventRegistration[]
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Volunteer {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  skills       String?
  availability String?
  message      String?
  createdAt    DateTime @default(now())
}

model Member {
  id                  String              @id @default(cuid())
  memberNumber        Int?                @unique
  nameAr              String
  nameNl              String
  birthYear           Int
  gender              String
  originCity          String
  whatsapp            String
  email               String?
  avatar              String?
  nlProvincie         String
  nlCity              String
  expNl               String?
  expOutside          String?
  educationLevel      String?
  profession          String?
  skills              String?
  maritalStatus       String?
  agreed              Boolean             @default(true)
  status              String              @default("pending")
  notes               String?
  encryptedIdCard     String?
  showInPublicProfile Boolean             @default(true)
  isCvPublic          Boolean             @default(true)
  isServiceProvider   Boolean             @default(false)
  isPremiumService    Boolean             @default(false)
  serviceDescription  String?
  userId              String?             @unique
  views               Int                 @default(0)
  createdAt           DateTime            @default(now())
  registrations       EventRegistration[]
  user                User?               @relation(fields: [userId], references: [id])
  documents           MemberDocument[]
  memberViews         MemberView[]
  serviceReviews      ServiceReview[]     @relation("MemberReviews")
  taskApplications    TaskApplication[]
}

model MemberView {
  id        String   @id @default(cuid())
  memberId  String
  viewerId  String?
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
}

model AppSetting {
  key   String @id
  value String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  memberId  String
  action    String
  details   String?
  userId    String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OtpCode {
  id         String   @id @default(cuid())
  identifier String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([identifier, code])
}

model Survey {
  id          String         @id @default(cuid())
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  options     SurveyOption[]
  votes       SurveyVote[]
}

model SurveyOption {
  id       String @id @default(cuid())
  surveyId String
  text     String
  votes    Int    @default(0)
  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model SurveyVote {
  id        String   @id @default(cuid())
  surveyId  String
  optionId  String
  userId    String
  createdAt DateTime @default(now())
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
}

model Ad {
  id        String    @id @default(cuid())
  title     String
  image     String
  link      String?
  position  String    @default("sidebar")
  startDate DateTime?
  endDate   DateTime?
  clicks    Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   @default("[]")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model UserPermission {
  id         String  @id @default(cuid())
  userId     String
  permission String
  granted    Boolean @default(true)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

model ChatAISession {
  id        String          @id @default(cuid())
  userId    String
  persona   String          @default("general")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  ChatAIMessage[]

  @@index([userId])
}

model ChatAIMessage {
  id        String        @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime      @default(now())
  session   ChatAISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Donation {
  id            String    @id @default(cuid())
  memberId      String?
  name          String
  email         String?
  phone         String?
  amount        Float
  currency      String    @default("EUR")
  message       String?
  paymentMethod String?   @default("bank")
  status        String    @default("pending")
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LandingPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  subtitle        String?
  heroImage       String?
  heroHeadline    String?
  heroSubheadline String?
  content         String   @default("")
  ctaText         String?
  ctaLink         String?
  features        String?
  themeColor      String   @default("#1a5632")
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Guide {
  id        String   @id @default(cuid())
  titleAr   String
  titleNl   String
  titleEn   String
  contentAr String
  contentNl String
  contentEn String
  category  String
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  memberId  String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
}

model TaskApplication {
  id        String   @id @default(cuid())
  taskId    String
  memberId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, memberId])
}

model BoardMember {
  id          String   @id @default(uuid())
  nameAr      String
  nameEn      String
  image       String
  titleAr     String
  titleEn     String
  isFounder   Boolean  @default(true)
  isLicensing Boolean  @default(false)
  committees  String
  bioPoints   String
  website     String?  @default("https://www.sy-nl.org/")
  kvkNumber   String   @default("96718943")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("board_members")
}

model FAQ {
  id         String   @id @default(cuid())
  questionAr String
  questionNl String
  questionEn String
  answerAr   String
  answerNl   String
  answerEn   String
  category   String
  tags       String?
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MobileTranslation {
  id        String   @id @default(cuid())
  key       String   @unique
  ar        String
  en        String
  nl        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberDocument {
  id        String   @id @default(cuid())
  memberId  String
  title     String
  fileUrl   String
  fileType  String?
  category  String?
  notes     String?
  analysis  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("pending")
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model Regulation {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  content     String   @default("[]")
  pdfPath     String?
  pdfSize     Int?
  version     Int      @default(1)
  published   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ServiceReview {
  id         String   @id @default(cuid())
  serviceId  String
  reviewerId String
  rating     Int      @default(5)
  comment    String?
  createdAt  DateTime @default(now())
  reviewer   User     @relation("UserReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  member     Member   @relation("MemberReviews", fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([reviewerId])
}
