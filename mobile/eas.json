{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "npm_config_legacy_peer_deps": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "EXPO_PUBLIC_API_URL": "https://sgn-indol.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "EXPO_PUBLIC_API_URL": "https://sy-nl.org"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
