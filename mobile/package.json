{
  "name": "sy-nl-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "set:dev": "npx tsx scripts/set-env.ts dev",
    "set:prod": "npx tsx scripts/set-env.ts prod",
    "build:android": "npm run set:prod && eas build --platform android",
    "build:ios": "npm run set:prod && eas build --platform ios",
    "build:web": "npm run set:prod && npx expo export --platform web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.3.0"
  },
  "private": true
}
