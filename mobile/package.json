{
  "name": "sy-nl-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "set:dev": "npx tsx scripts/set-env.ts dev",
    "set:prod": "npx tsx scripts/set-env.ts prod",
    "build:android": "npm run set:prod && expo build:android",
    "build:ios": "npm run set:prod && expo build:ios",
    "build:web": "npm run set:prod && expo export:web"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "2.1.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-device": "~7.0.0",
    "expo-linking": "~7.0.0",
    "expo-notifications": "~0.30.0",
    "expo-router": "~5.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.0",
    "react-native-safe-area-context": "5.3.0",
    "react-native-screens": "~4.11.0",
    "react-native-web": "~0.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.0",
    "typescript": "^5.3.0"
  },
  "private": true
}
