DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="https://sy-nl.org"
# AI Provider: "ollama" | "openai" | "auto" (auto = ollama in dev, openai in prod)
AI_PROVIDER="auto"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
NEXT_PUBLIC_APP_URL="https://sy-nl.org"

# Sync
SYNC_INTERVAL="0 * * * *"
SYNC_MEDIA_DIR="public/uploads/sync"
SYNC_AUTO_CATEGORIZE="true"
SYNC_DOWNLOAD_MEDIA="true"

# Mobile App
# Set this to your dev server URL when testing the mobile app locally
EXPO_PUBLIC_API_URL="http://localhost:3001"
# Run `cd mobile && npm run set:prod` before building APK/IPA for production

# Facebook Sync
FACEBOOK_PAGE_ID="61584301535331"
FACEBOOK_PAGE_TOKEN=""
FACEBOOK_PAGE_SLUG="DeSyrischeGemeenschapInNederland"

